{
  "name": "devlock",
  "version": "1.0.0",
  "private": true,
  "description": "DevLock — Software Licensing, Remote Management & Developer Protection Platform",
  "scripts": {
    "dev": "npm run dev --prefix frontend & npm run dev --prefix backend",
    "build": "npm run build --prefix backend && npm run build --prefix frontend",
    "start": "npm start --prefix backend & npm start --prefix frontend",
    "install:all": "npm install && npm install --prefix frontend && npm install --prefix backend",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:build": "docker compose -f docker/docker-compose.yml build",
    "docker:prod": "docker compose -f docker/docker-compose.prod.yml up -d",
    "generate:keys": "tsx scripts/generate-keys.ts",
    "prepare": "husky",
    "commitlint": "commitlint --edit"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tsx": "^4.15.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
