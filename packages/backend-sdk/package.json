{
  "name": "@devlock/backend-sdk",
  "version": "0.1.0",
  "description": "DevLock Backend SDK — License enforcement and remote management for Node.js",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./express": {
      "types": "./dist/middleware/express.d.ts",
      "import": "./dist/middleware/express.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "clean": "rm -rf dist .turbo",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "test": "vitest run",
    "test:ci": "vitest run --coverage"
  },
  "dependencies": {
    "@devlock/shared-types": "workspace:*",
    "socket.io-client": "^4.7.0"
  },
  "devDependencies": {
    "@devlock/eslint-config": "workspace:*",
    "@devlock/tsconfig": "workspace:*",
    "@types/express": "^4.17.21",
    "eslint": "^8.57.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "express": "^4.18.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "express": { "optional": true }
  },
  "keywords": ["devlock", "sdk", "node", "express", "licensing"]
}
