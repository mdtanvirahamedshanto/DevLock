{
  "name": "@devlock/database",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./models": {
      "types": "./dist/models/index.d.ts",
      "import": "./dist/models/index.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "clean": "rm -rf dist .turbo",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "db:seed": "tsx src/seeds/index.ts",
    "db:migrate": "tsx src/migrations/index.ts"
  },
  "dependencies": {
    "@devlock/shared-types": "workspace:*",
    "@devlock/logger": "workspace:*",
    "mongoose": "^8.4.0",
    "ioredis": "^5.4.0"
  },
  "devDependencies": {
    "@devlock/eslint-config": "workspace:*",
    "@devlock/tsconfig": "workspace:*",
    "eslint": "^8.57.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0"
  }
}
