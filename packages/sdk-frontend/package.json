{
  "name": "@devlock/sdk-frontend",
  "version": "0.1.0",
  "description": "DevLock Frontend SDK - License enforcement and remote management for browser applications",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "socket.io-client": "^4.7.0"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^11.1.0",
    "@rollup/plugin-terser": "^0.4.0",
    "rollup": "^4.18.0",
    "typescript": "^5.5.0",
    "tslib": "^2.6.0"
  },
  "keywords": ["devlock", "sdk", "licensing", "remote-management", "feature-flags"],
  "license": "MIT"
}
