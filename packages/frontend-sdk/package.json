{
  "name": "@devlock/frontend-sdk",
  "version": "0.1.0",
  "description": "DevLock Frontend SDK — License enforcement and remote management for browser apps",
  "license": "MIT",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --minify",
    "clean": "rm -rf dist .turbo",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "test": "vitest run",
    "test:ci": "vitest run --coverage"
  },
  "dependencies": {
    "@devlock/shared-types": "workspace:*",
    "socket.io-client": "^4.7.0"
  },
  "devDependencies": {
    "@devlock/eslint-config": "workspace:*",
    "@devlock/tsconfig": "workspace:*",
    "eslint": "^8.57.0",
    "tsup": "^8.1.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "keywords": ["devlock", "sdk", "licensing", "feature-flags", "remote-management"]
}
