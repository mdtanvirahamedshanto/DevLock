# =============================================================================
# DevLock Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# General
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000
DASHBOARD_URL=http://localhost:4000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/devlock?replicaSet=rs0
MONGODB_DB_NAME=devlock

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT & Auth
JWT_SECRET=your-jwt-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Ed25519 Keys (for license signing)
# Generate with: pnpm generate:keys
LICENSE_PRIVATE_KEY=
LICENSE_PUBLIC_KEY=

# Stripe (Billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# Email (Notifications)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@devlock.io

# Socket.IO
WEBSOCKET_PORT=3010
WEBSOCKET_CORS_ORIGIN=http://localhost:4000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Encryption
ENCRYPTION_KEY=32-byte-hex-key-for-field-encryption

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# External Services
CLOUDFLARE_API_TOKEN=
SENTRY_DSN=
