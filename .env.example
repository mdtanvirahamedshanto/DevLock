
NODE_ENV=development
LOG_LEVEL=debug

# ── Service Ports ─────────────────────────────────────────────────────────────
# API_GATEWAY_PORT=3000
# AUTH_SERVICE_PORT=3001
# LICENSE_SERVICE_PORT=3002
# TELEMETRY_SERVICE_PORT=3003
# NOTIFICATION_SERVICE_PORT=3004
# BILLING_SERVICE_PORT=3005
# WEBSOCKET_SERVICE_PORT=3010
# WEB_DASHBOARD_PORT=4000

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/devlock?replicaSet=rs0
MONGODB_MAX_POOL_SIZE=50
MONGODB_MIN_POOL_SIZE=5

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=devlock:

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET=-PvZeIcq0N9-jb6Vkx_vpkTjkceczhxoBBoEqCVWMwDj8vTHsyHdSD98H9aIDUxp
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
BCRYPT_ROUNDS=12

# ── Encryption ────────────────────────────────────────────────────────────────
# 64 hex chars = 32 bytes for AES-256
ENCRYPTION_KEY=2538a63a27bd0d4ed8e8eb131be01ab65881280fc609149ac40b1b0f3cd3452d

# ── License Signing (Ed25519) ─────────────────────────────────────────────────
# Generate with: pnpm generate:keys
LICENSE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMC4CAQAwBQYDK2VwBCIEIM6UBicEBu0r9VRLMMQQ1Bc0IMTK9RTbFPWVDuh07CcH\n-----END PRIVATE KEY-----\n"
LICENSE_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMCowBQYDK2VwAyEAsU3YK1pK3Hi7j1iPVmTtsct4et+L9GEV/qRkIRUEu+A=\n-----END PUBLIC KEY-----\n"

# ── Service URLs ──────────────────────────────────────────────────────────────
API_GATEWAY_URL=https://dl-api.tashanto.com
NEXT_PUBLIC_API_URL=https://dl-api.tashanto.com/v1
NEXT_PUBLIC_DASHBOARD_URL=https://devlock.tashanto.com 
WEBSOCKET_URL=https://dl-ws.tashanto.com
DASHBOARD_URL=http://localhost:4000

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:4000,http://localhost:3000, https://devlock.tashanto.com
WS_CORS_ORIGIN=https://devlock.tashanto.com

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100

# ── Stripe (Billing) ─────────────────────────────────────────────────────────
